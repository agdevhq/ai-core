{
    "name": "@core-ai/opentelemetry",
    "version": "0.10.0",
    "description": "OpenTelemetry middleware for @core-ai/core-ai",
    "license": "MIT",
    "author": "Omnifact (https://omnifact.ai)",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/agdevhq/core-ai.git",
        "directory": "packages/opentelemetry"
    },
    "keywords": [
        "llm",
        "ai",
        "sdk",
        "opentelemetry",
        "observability"
    ],
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "scripts": {
        "build": "tsup",
        "lint": "eslint src/ --max-warnings 0",
        "check-types": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@core-ai/core-ai": "^0.10.0"
    },
    "peerDependencies": {
        "@opentelemetry/api": "^1.9.1"
    },
    "devDependencies": {
        "@core-ai/eslint-config": "*",
        "@core-ai/typescript-config": "*",
        "@opentelemetry/api": "^1.9.1",
        "@opentelemetry/context-async-hooks": "^2.6.1",
        "@opentelemetry/sdk-trace-base": "^2.6.1",
        "typescript": "^5.7.3",
        "vitest": "^3.2.4",
        "zod": "^4.0.0"
    }
}
