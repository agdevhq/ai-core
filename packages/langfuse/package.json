{
    "name": "@core-ai/langfuse",
    "version": "0.10.1",
    "description": "Langfuse middleware for @core-ai/core-ai",
    "license": "MIT",
    "author": "Omnifact (https://omnifact.ai)",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/agdevhq/core-ai.git",
        "directory": "packages/langfuse"
    },
    "keywords": [
        "llm",
        "ai",
        "langfuse",
        "observability"
    ],
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "scripts": {
        "build": "tsup",
        "lint": "eslint src/ --max-warnings 0",
        "check-types": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@core-ai/core-ai": "^0.10.1"
    },
    "peerDependencies": {
        "@langfuse/otel": "^5.1.0",
        "@langfuse/tracing": "^5.1.0"
    },
    "devDependencies": {
        "@core-ai/eslint-config": "*",
        "@core-ai/typescript-config": "*",
        "@langfuse/otel": "^5.1.0",
        "@langfuse/tracing": "^5.1.0",
        "@opentelemetry/sdk-node": "^0.214.0",
        "typescript": "^5.7.3",
        "vitest": "^3.2.4",
        "zod": "^4.3.6"
    }
}
